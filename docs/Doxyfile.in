PROJECT_NAME = "Graphite"
OUTPUT_DIRECTORY       = @CMAKE_CURRENT_SOURCE_DIR@/docs/
INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/src/ @CMAKE_CURRENT_SOURCE_DIR@/include/ @CMAKE_CURRENT_SOURCE_DIR@/docs/markdown/
RECURSIVE              = YES
EXTRACT_PRIVATE        = YES
GENERATE_HTML          = YES
GENERATE_XML           = YES


GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_EXTRA_FILES       = @AWESOME_CSS_DIR@/doxygen-awesome-darkmode-toggle.js \
                         @AWESOME_CSS_DIR@/doxygen-awesome-fragment-copy-button.js
HTML_EXTRA_STYLESHEET  = @AWESOME_CSS_DIR@/doxygen-awesome.css \
                         @AWESOME_CSS_DIR@/doxygen-awesome-sidebar-only.css \ 
                         @AWESOME_CSS_DIR@/doxygen-awesome-sidebar-only-darkmode-toggle.css
HTML_COLORSTYLE        = LIGHT 
HTML_HEADER = @CMAKE_CURRENT_SOURCE_DIR@/docs/header.html
HTML_COPY_CLIPBOARD = NO